<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Truck Servicing Log</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      padding: 2em;
      background-color: #f4f4f4;
    }
    .container {
      background: white;
      padding: 2em;
      border-radius: 10px;
      max-width: 400px;
      margin: auto;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    label {
      display: block;
      margin-top: 1em;
    }
    input {
      width: 100%;
      padding: 0.5em;
      margin-top: 0.5em;
    }
    button {
      margin-top: 1.5em;
      padding: 0.75em;
      width: 100%;
      background-color: #28a745;
      color: white;
      border: none;
      font-size: 1em;
      cursor: pointer;
    }
    button:hover {
      background-color: #218838;
    }
  </style>
</head>
<body>
  <div class="container">
    <h2>Truck Servicing Form</h2>
    <form id="servicingForm">
      <label for="driverName">Driver Name:</label>
      <input type="text" id="driverName" name="driverName" required />

      <label for="truckNumber">Truck Number:</label>
      <input type="text" id="truckNumber" name="truckNumber" required />

      <label for="servicingDate">Servicing Date:</label>
      <input type="date" id="servicingDate" name="servicingDate" required />

      <label for="mileage">Mileage (km):</label>
      <input type="number" id="mileage" name="mileage" required />

      <button type="submit">Submit</button>
    </form>
  </div>

  <script>
    document.getElementById("servicingForm").addEventListener("submit", function(e) {
      e.preventDefault();
      const driverName = document.getElementById("driverName").value;
      const truckNumber = document.getElementById("truckNumber").value;
      const date = document.getElementById("servicingDate").value;
      const mileage = document.getElementById("mileage").value;
      
      // You can send this data to your server or Google Sheets
      console.log("Driver Name:", driverName);
      console.log("Truck Number:", truckNumber);
      console.log("Servicing Date:", date);
      console.log("Mileage:", mileage);
      
      alert("Form submitted successfully!");
      this.reset();
    });
  </script>
</body>
</html>
